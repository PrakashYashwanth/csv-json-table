{
  "name": "csv-json-table",
  "displayName": "CSV JSON Table",
  "description": "Fast CSV editor with built-in JSON intelligence — perfect for developers handling structured data",
  "version": "0.0.1",
  "publisher": "mssprakashyashwanth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrakashYashwanth/csv-json-table.git"
  },
  "bugs": {
    "url": "https://github.com/PrakashYashwanth/csv-json-table/issues"
  },
  "homepage": "https://github.com/PrakashYashwanth/csv-json-table#readme",
  "icon": "./media/icon.svg",
  "keywords": [
    "csv",
    "json",
    "table",
    "editor",
    "spreadsheet",
    "data",
    "config",
    "viewer"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Data & Analytics",
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:csvJsonTable.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "csvJsonTable.open",
        "title": "Open CSV as Config Table"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .csv",
          "command": "csvJsonTable.open",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "tsc -p ./",
    "compile:webview": "esbuild src/webview/main.ts --bundle --outfile=media/webview.js --platform=browser --format=esm",
    "watch": "tsc -watch -p ./",
    "watch:webview": "esbuild src/webview/main.ts --bundle --outfile=media/webview.js --platform=browser --format=esm --watch",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/papaparse": "^5.3.14",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.3"
  }
}
